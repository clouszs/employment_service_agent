# 配置模板：复制为 .env 后填写实际值
APP_NAME=就业指导中心RAG问答系统
APP_ENV=dev
APP_DEBUG=true

# 服务监听地址（直接运行 main.py 时生效）
SERVER_HOST=127.0.0.1
SERVER_PORT=8000

# 数据库
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=claudecode_rag
DB_CHARSET=utf8mb4

# 数据库连接池
DB_POOL_SIZE=10
DB_POOL_RECYCLE=3600
DB_ECHO=false

# JWT 鉴权
JWT_SECRET=your-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=720

# 文件上传
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=50

# RAG：DashScope(阿里百炼)
DASHSCOPE_API_KEY=your-dashscope-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=1024
LLM_MODEL=qwen3.7-max

# 语义分块（基于句子嵌入相似度的百分位落差法）
CHUNK_MIN_CHARS=200
CHUNK_MAX_CHARS=500
SEMANTIC_BREAKPOINT_PERCENTILE=95

# 向量库(Chroma 本地)
CHROMA_DIR=chroma_data
CHROMA_COLLECTION=kb_chunks

# 检索问答
RETRIEVE_TOP_K=5
RETRIEVE_SCORE_THRESHOLD=0.4

# FAQ 命中优先
FAQ_COLLECTION=kb_faqs
FAQ_SCORE_THRESHOLD=0.75
